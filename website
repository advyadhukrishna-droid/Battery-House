      </svg>
      <div class="product-name">UPS Systems</div>
      <div class="product-desc">Uninterruptible power supplies for homes, offices, and critical equipment. Protects against outages and surges.</div>
      <span class="product-tag">Protection</span>
    </div>

    <div class="product-card">
      <svg class="product-icon" viewBox="0 0 40 40" fill="none">
