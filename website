      <span class="product-tag">Hardware</span>
    </div>

  </div>
</section>

<!-- WHY US -->
<section class="why" id="why">
  <div class="section-header">
    <h2 class="section-title">Why Battery House</h2>
  </div>
  <div class="why-grid">
    <div class="why-item">
      <div class="why-num">Quality</div>
      <div class="why-title">Only tier-1 brands</div>
      <div class="why-desc">We stock products from manufacturers with proven track records — no grey-market imports, no compromises on specification.</div>
