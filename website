<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Battery House — Solar & Inverter Solutions</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #F8F8F6;
      --ink: #111111;
      --mid: #888888;
      --rule: #DDDDD8;
      --accent: #E8A020;
      --white: #ffffff;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--ink);
      font-size: 16px;
      line-height: 1.6;
    }

    /* NAV */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 48px;
      height: 64px;
      background: var(--bg);
      border-bottom: 1px solid var(--rule);
    }

    .nav-logo {
      font-size: 15px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--ink);
      text-decoration: none;
    }

    .nav-logo span { color: var(--accent); }

    .nav-links {
      display: flex;
      gap: 36px;
      list-style: none;
    }

    .nav-links a {
      font-size: 13px;
      font-weight: 400;
      color: var(--mid);
      text-decoration: none;
      letter-spacing: 0.04em;
      transition: color 0.2s;
    }

    .nav-links a:hover { color: var(--ink); }

    .nav-cta {
      font-size: 13px;
      font-weight: 500;
      color: var(--ink);
      text-decoration: none;
      border-bottom: 1.5px solid var(--accent);
      padding-bottom: 1px;
    }

    /* HERO */
    .hero {
      min-height: 100vh;
      padding-top: 64px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: center;
    }

    .hero-text {
      padding: 80px 48px 80px 48px;
    }

    .hero-eyebrow {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 28px;
    }

    .hero-title {
      font-size: clamp(48px, 5vw, 80px);
      font-weight: 900;
      line-height: 1.0;
      letter-spacing: -0.03em;
      color: var(--ink);
      margin-bottom: 28px;
    }

    .hero-title em {
      font-style: normal;
      color: var(--accent);
    }

    .hero-sub {
      font-size: 17px;
      font-weight: 300;
      color: var(--mid);
      max-width: 380px;
      line-height: 1.7;
      margin-bottom: 48px;
    }

    .hero-actions {
      display: flex;
      gap: 20px;
      align-items: center;
    }

    .btn-primary {
      display: inline-block;
      background: var(--ink);
      color: var(--white);
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 0.06em;
      text-decoration: none;
      padding: 14px 28px;
      transition: background 0.2s;
    }

    .btn-primary:hover { background: var(--accent); }

    .btn-ghost {
      font-size: 13px;
      font-weight: 400;
      color: var(--mid);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 6px;
      transition: color 0.2s;
    }

    .btn-ghost:hover { color: var(--ink); }
    .btn-ghost::after { content: "→"; }

    /* Hero SVG panel */
    .hero-visual {
      height: 100vh;
      background: var(--ink);
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }

    .hero-visual svg {
      width: 340px;
      height: 340px;
    }

    @keyframes rotateArc {
      from { transform: rotate(0deg); }
      to   { transform: rotate(360deg); }
    }

    @keyframes pulseDot {
      0%, 100% { opacity: 1; r: 5; }
      50%       { opacity: 0.3; r: 8; }
    }

    @media (prefers-reduced-motion: reduce) {
      .arc-spin, .arc-spin2 { animation: none; }
    }

    .arc-spin {
      transform-origin: 170px 170px;
      animation: rotateArc 6s linear infinite;
    }
    .arc-spin2 {
      transform-origin: 170px 170px;
      animation: rotateArc 10s linear infinite reverse;
    }

    .hero-label {
      position: absolute;
      bottom: 40px;
      right: 40px;
      font-size: 11px;
      font-weight: 400;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #444;
    }

    /* STATS */
    .stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border-top: 1px solid var(--rule);
      border-bottom: 1px solid var(--rule);
    }

    .stat {
      padding: 48px;
      border-right: 1px solid var(--rule);
    }

    .stat:last-child { border-right: none; }

    .stat-num {
      font-size: 52px;
      font-weight: 900;
      letter-spacing: -0.03em;
      line-height: 1;
      color: var(--ink);
      margin-bottom: 8px;
    }

    .stat-num span { color: var(--accent); }

    .stat-label {
      font-size: 13px;
      font-weight: 400;
      color: var(--mid);
      letter-spacing: 0.04em;
    }

    /* PRODUCTS */
    .section {
      padding: 96px 48px;
    }

    .section-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 64px;
      border-bottom: 1px solid var(--rule);
      padding-bottom: 24px;
    }

    .section-title {
      font-size: 36px;
      font-weight: 700;
      letter-spacing: -0.02em;
    }

    .section-link {
      font-size: 13px;
      font-weight: 400;
      color: var(--mid);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 6px;
      transition: color 0.2s;
    }

    .section-link:hover { color: var(--accent); }
    .section-link::after { content: "→"; }

    .products-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--rule);
    }

    .product-card {
      background: var(--bg);
      padding: 40px 36px;
      display: flex;
      flex-direction: column;
      gap: 16px;
      transition: background 0.2s;
      cursor: pointer;
    }

    .product-card:hover { background: var(--white); }

    .product-icon {
      width: 40px;
      height: 40px;
      color: var(--accent);
    }

    .product-name {
      font-size: 20px;
      font-weight: 700;
      letter-spacing: -0.01em;
    }

    .product-desc {
      font-size: 14px;
      font-weight: 300;
      color: var(--mid);
      line-height: 1.65;
    }

    .product-tag {
      display: inline-block;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
      margin-top: auto;
      padding-top: 12px;
      border-top: 1px solid var(--rule);
    }

    /* WHY US */
    .why {
      background: var(--ink);
      color: var(--white);
      padding: 96px 48px;
    }

    .why .section-header { border-bottom-color: #333; }
    .why .section-title { color: var(--white); }
    .why .section-link { color: #666; }
    .why .section-link:hover { color: var(--accent); }

    .why-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 48px 64px;
    }

    .why-item {}

    .why-num {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 16px;
    }

    .why-title {
      font-size: 22px;
      font-weight: 700;
      letter-spacing: -0.01em;
      margin-bottom: 12px;
      color: var(--white);
    }

    .why-desc {
      font-size: 14px;
      font-weight: 300;
      color: #888;
      line-height: 1.7;
    }

    /* CONTACT */
    .contact {
      padding: 96px 48px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: start;
    }

    .contact-left {}

    .contact-eyebrow {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 24px;
    }

    .contact-title {
      font-size: 40px;
      font-weight: 700;
      letter-spacing: -0.02em;
      line-height: 1.1;
      margin-bottom: 24px;
    }

    .contact-body {
      font-size: 14px;
      font-weight: 300;
      color: var(--mid);
      line-height: 1.7;
      margin-bottom: 40px;
    }

    .contact-details {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .contact-detail {
      display: flex;
      gap: 12px;
      font-size: 14px;
    }

    .contact-detail-label {
      font-weight: 500;
      min-width: 80px;
      color: var(--ink);
    }

    .contact-detail-val {
      color: var(--mid);
    }

    .contact-form {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .form-label {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--mid);
    }

    .form-input, .form-textarea {
      background: transparent;
      border: none;
      border-bottom: 1px solid var(--rule);
      padding: 10px 0;
      font-family: 'Inter', sans-serif;
      font-size: 15px;
      font-weight: 300;
      color: var(--ink);
      outline: none;
      transition: border-color 0.2s;
      width: 100%;
    }

    .form-input:focus, .form-textarea:focus {
      border-bottom-color: var(--accent);
    }

    .form-textarea { resize: none; height: 80px; }

    .form-submit {
      background: var(--accent);
      border: none;
      color: var(--white);
      font-family: 'Inter', sans-serif;
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 16px 32px;
      cursor: pointer;
      align-self: flex-start;
      transition: background 0.2s;
    }

    .form-submit:hover { background: var(--ink); }

    /* FOOTER */
    footer {
      border-top: 1px solid var(--rule);
      padding: 32px 48px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .footer-copy {
      font-size: 12px;
      font-weight: 400;
      color: var(--mid);
    }

    .footer-links {
      display: flex;
      gap: 24px;
      list-style: none;
    }

    .footer-links a {
      font-size: 12px;
      color: var(--mid);
      text-decoration: none;
      transition: color 0.2s;
    }

    .footer-links a:hover { color: var(--ink); }

    /* RESPONSIVE */
    @media (max-width: 900px) {
      nav { padding: 0 24px; }
      .nav-links { display: none; }
      .hero { grid-template-columns: 1fr; }
      .hero-visual { display: none; }
      .hero-text { padding: 80px 24px 60px; }
      .stats { grid-template-columns: 1fr; }
      .stat { border-right: none; border-bottom: 1px solid var(--rule); }
      .stat:last-child { border-bottom: none; }
      .section { padding: 64px 24px; }
      .why { padding: 64px 24px; }
      .products-grid { grid-template-columns: 1fr; }
      .why-grid { grid-template-columns: 1fr; gap: 40px; }
      .contact { grid-template-columns: 1fr; padding: 64px 24px; gap: 48px; }
      footer { flex-direction: column; gap: 16px; padding: 28px 24px; }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <a class="nav-logo" href="#">Battery <span>House</span></a>
  <ul class="nav-links">
    <li><a href="#products">Products</a></li>
    <li><a href="#why">Why Us</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
  <a class="nav-cta" href="#contact">Get a Quote</a>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-text">
    <p class="hero-eyebrow">Solar · Inverter · Battery</p>
    <h1 class="hero-title">Power<br/>that <em>lasts.</em></h1>
    <p class="hero-sub">Battery House supplies premium solar panels, inverters, and energy storage solutions for homes and businesses across the region.</p>
    <div class="hero-actions">
      <a href="#products" class="btn-primary">View Products</a>
      <a href="#contact" class="btn-ghost">Talk to us</a>
    </div>
  </div>

  <div class="hero-visual">
    <svg viewBox="0 0 340 340" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Outer rotating arc -->
      <g class="arc-spin">
        <circle cx="170" cy="170" r="140" stroke="#222" stroke-width="1"/>
        <path d="M 170 30 A 140 140 0 0 1 310 170" stroke="#E8A020" stroke-width="2" stroke-linecap="round"/>
      </g>
      <!-- Inner rotating arc (reverse) -->
      <g class="arc-spin2">
        <circle cx="170" cy="170" r="100" stroke="#1a1a1a" stroke-width="1"/>
        <path d="M 170 70 A 100 100 0 0 0 70 170" stroke="#E8A020" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>
      </g>
      <!-- Center battery bolt -->
      <path d="M 180 130 L 158 175 L 172 175 L 162 215 L 186 168 L 170 168 Z" fill="#E8A020"/>
      <!-- Static ring -->
      <circle cx="170" cy="170" r="58" stroke="#2a2a2a" stroke-width="1"/>
    </svg>
    <span class="hero-label">Est. Kerala, India</span>
  </div>
</section>

<!-- STATS -->
<div class="stats">
  <div class="stat">
    <div class="stat-num">500<span>+</span></div>
    <div class="stat-label">Installations completed</div>
  </div>
  <div class="stat">
    <div class="stat-num">12<span>+</span></div>
    <div class="stat-label">Years in the industry</div>
  </div>
  <div class="stat">
    <div class="stat-num">98<span>%</span></div>
    <div class="stat-label">Customer satisfaction</div>
  </div>
</div>

<!-- PRODUCTS -->
<section class="section" id="products">
  <div class="section-header">
    <h2 class="section-title">Products</h2>
    <a href="#contact" class="section-link">Request a product</a>
  </div>

  <div class="products-grid">

    <div class="product-card">
