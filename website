        <span class="contact-detail-label">Hours</span>
        <span class="contact-detail-val">Mon – Sat, 9 am – 6 pm</span>
      </div>
    </div>
  </div>

  <div class="contact-form">
    <div class="form-group">
      <label class="form-label">Your name</label>
      <input class="form-input" type="text" placeholder="Rajan Menon" />
    </div>
    <div class="form-group">
      <label class="form-label">Phone / Email</label>
      <input class="form-input" type="text" placeholder="+91 or your email" />
    </div>
    <div class="form-group">
      <label class="form-label">What do you need?</label>
      <textarea class="form-textarea" placeholder="e.g. 5kW solar system for home, replacement inverter, etc."></textarea>
    </div>
    <button class="form-submit">Send enquiry</button>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <span class="footer-copy">© 2026 Battery House. All rights reserved.</span>
  <ul class="footer-links">
    <li><a href="#products">Products</a></li>
    <li><a href="#why">About</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
</footer>

</body>
</html>
